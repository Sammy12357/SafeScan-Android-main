{
  "expo": {
    "name": "SafeScan QR",
    "slug": "safescan-android",
    "scheme": "safescan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#0a0a0f"
    },
    "android": {
      "package": "com.safescan.qr",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-foreground.png",
        "backgroundColor": "#0a0a0f"
      },
      "permissions": ["CAMERA", "INTERNET", "VIBRATE", "USE_BIOMETRIC"],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "safescan" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      ["expo-router", { "root": "./app" }],
      ["expo-camera", { "cameraPermission": "SafeScan needs camera to scan QR codes." }],
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}
